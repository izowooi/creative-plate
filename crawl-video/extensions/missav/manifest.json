{
  "manifest_version": 3,
  "name": "MissAV Video Downloader",
  "version": "1.0",
  "description": "missav.ai에서 영상을 HLS 스트림으로 다운로드",
  "permissions": ["downloads", "storage"],
  "host_permissions": [
    "https://missav.ai/*",
    "https://surrit.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://missav.ai/*"],
    "js": ["content_script.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MissAV Downloader"
  }
}
